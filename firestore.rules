rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "fast8585100@gmail.com");
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'category', 'author', 'date', 'image']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.slug is string && data.slug.size() > 0 &&
             data.content is string && data.content.size() > 0 &&
             data.category is string &&
             data.author is string &&
             data.date is string &&
             data.image is string;
    }

    match /posts/{postId} {
      // Public read access
      allow read: if true;
      
      // Admin-only write access
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
